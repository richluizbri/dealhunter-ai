// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Product {
  id           Int      @id @default(autoincrement())

  // [CORREÇÃO] @unique adicionado para garantir que não existam dois
  // produtos com o mesmo título no banco — e para habilitar o upsert
  // nativo do Prisma no repository (where: { titulo: ... }).
  titulo       String   @unique @db.VarChar(500)

  precoUSD     Float
  precoBRL     Float
  exchangeRate Float?
  imagem       String?  @db.VarChar(1000)
  url          String?  @db.VarChar(1000)
  rating       String?  @db.VarChar(50)
  createdAt    DateTime @default(now())

  history      PriceHistory[]
}

model PriceHistory {
  id         Int      @id @default(autoincrement())
  productId  Int
  preco      Float
  createdAt  DateTime @default(now())

  product    Product  @relation(fields: [productId], references: [id])
}